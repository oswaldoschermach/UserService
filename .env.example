# ============================================================
# UserService - Variaveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositorio.
# ============================================================
# Servidor
SERVER_PORT=35698
# Banco de dados PostgreSQL
DB_NAME=userservice
DB_USERNAME=postgres
DB_PASSWORD=troque_por_uma_senha_forte
DB_PORT=5432
# JWT
# Gere uma chave Base64 segura (minimo 256 bits) com:
#   openssl rand -base64 32
JWT_SECRET=troque_por_sua_chave_base64_aqui
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000
# Redis — blacklist de tokens e rate limiting
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# E-mail
# Para dev: deixe MAIL_HOST=mailhog e MAIL_PORT=1025
# Para prod: configure com seu provedor SMTP (ex: Gmail)
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=dev@localhost
MAIL_PASSWORD=
# CORS — dominios do frontend separados por virgula
# Em producao, substitua pelos dominios reais
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200
# Rate limiting — endpoint POST /api/users/createUser
# Padrao: 10 requisicoes por IP a cada 60 segundos
RATE_LIMIT_CREATE_USER_CAPACITY=10
RATE_LIMIT_CREATE_USER_REFILL=10
RATE_LIMIT_CREATE_USER_SECONDS=60
# Spring Profile
# dev  -> ddl-auto: update, show-sql: true, SMTP local, Flyway desabilitado
# (sem perfil) -> producao, ddl-auto: validate, SMTP real, Flyway habilitado
SPRING_PROFILES_ACTIVE=dev